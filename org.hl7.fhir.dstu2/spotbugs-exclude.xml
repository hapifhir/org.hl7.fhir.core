<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        Generated DSTU2 model classes contain EC_UNRELATED_TYPES in has*() methods
        that accept List<StringType> but compare with String via contains(). These are
        generated code and should not be edited directly.
    -->
    <Match>
        <Bug pattern="EC_UNRELATED_TYPES"/>
        <Class name="~org\.hl7\.fhir\.dstu2\.model\..*"/>
    </Match>
</FindBugsFilter>
