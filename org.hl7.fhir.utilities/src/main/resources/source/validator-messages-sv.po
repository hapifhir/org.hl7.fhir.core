# ABSTRACT_CODE_NOT_ALLOWED
#: ABSTRACT_CODE_NOT_ALLOWED
msgid "Code ''{0}#{1}'' is abstract, and not allowed in this context"
msgstr "Koden ''{0}#{1}'' är abstrakt och inte tillåten i denna kontext"

# ALL_OK
#: ALL_OK
msgid "All OK"
msgstr "Allt OK"

# ARRAY_CANNOT_BE_EMPTY
#: ARRAY_CANNOT_BE_EMPTY
msgid "Array cannot be empty - the property should not be present if it has no values"
msgstr "Array kan inte vara tom - egenskapen bör inte finnas om den saknar värden"

# ATTEMPT_TO_CHANGE_SLICING
#: ATTEMPT_TO_CHANGE_SLICING
msgid "The element at {0} defines the slicing {1} but then an element in the slicing {2} tries to redefine the slicing to {3}"
msgstr "Elementet vid {0} definierar uppdelningen {1} men ett element i uppdelningen {2} försöker omdefiniera uppdelningen till {3}"

# Adding_wrong_path
#: Adding_wrong_path
msgid "Adding wrong path"
msgstr "Lägger till fel sökväg"

# Adding_wrong_path__outcomegetPath___resultPathBase__
#: Adding_wrong_path__outcomegetPath___resultPathBase__
msgid "Adding wrong path - outcome.getPath() = {0}, resultPathBase = {1}"
msgstr "Lägger till fel sökväg - outcome.getPath() = {0}, resultPathBase = {1}"

# Adding_wrong_path_in_profile___vs_
#: Adding_wrong_path_in_profile___vs_
msgid "Adding wrong path in profile {0}: {1} vs {2}"
msgstr "Lägger till fel sökväg i profil {0}: {1} mot {2}"

# All_observations_should_have_a_performer
#: All_observations_should_have_a_performer
msgid "Best Practice Recommendation: In general, all observations should have a performer"
msgstr "Rekommendation för bästa praxis: Generellt bör alla observationer ha en utförare"

# All_observations_should_have_a_subject
#: All_observations_should_have_a_subject
msgid "Best Practice Recommendation: In general, all observations should have a subject"
msgstr "Rekommendation för bästa praxis: Generellt bör alla observationer ha ett subjekt"

# All_observations_should_have_an_effectiveDateTime_or_an_effectivePeriod
#: All_observations_should_have_an_effectiveDateTime_or_an_effectivePeriod
msgid "Best Practice Recommendation: In general, all observations should have an effective[x] ({0})"
msgstr "Rekommendation för bästa praxis: Generellt bör alla observationer ha en effective[x] ({0})"

# Attempt_to_a_slice_an_element_that_does_not_repeat__from__in_
#: Attempt_to_a_slice_an_element_that_does_not_repeat__from__in_
msgid "Attempt to a slice an element that does not repeat: {0}/{1} from {2} in {3}, at element {4} (slice = {5})"
msgstr "Försök att dela upp ett element som inte upprepas: {0}/{1} från {2} i {3}, vid element {4} (slice = {5})"

# Attempt_to_replace_element_name_for_a_nonchoice_type
#: Attempt_to_replace_element_name_for_a_nonchoice_type
msgid "Attempt to replace element name for a non-choice type"
msgstr "Försök att ersätta elementnamn för en icke-valbar typ"

# Attempt_to_use_Terminology_server_when_no_Terminology_server_is_available
#: Attempt_to_use_Terminology_server_when_no_Terminology_server_is_available
msgid "Attempt to use Terminology server when no Terminology server is available"
msgstr "Försök att använda terminologiserver när ingen terminologiserver är tillgänglig"

# Attempt_to_use_a_snapshot_on_profile__as__before_it_is_generated
#: Attempt_to_use_a_snapshot_on_profile__as__before_it_is_generated
msgid "Attempt to use a snapshot on profile ''{0}'' as {1} before it is generated"
msgstr "Försök att använda en snapshot på profil ''{0}'' som {1} innan den har genererats"

# BINDING_ADDITIONAL_D
#: BINDING_ADDITIONAL_D
msgid "{0} specified in an additional binding"
msgstr "{0} angiven i en ytterligare bindning"

# BINDING_ADDITIONAL_UC
#: BINDING_ADDITIONAL_UC
msgid "{0} specified in an additional binding which applies because {1}"
msgstr "{0} angiven i en ytterligare bindning som gäller eftersom {1}"

# BINDING_ADDITIONAL_USAGE
#: BINDING_ADDITIONAL_USAGE
msgid "{0} = {1}"
msgstr "{0} = {1}"

# BINDING_MAX
#: BINDING_MAX
msgid "{0} specified in the max binding"
msgstr "{0} angiven i maxbindningen"

# BUNDLE_BUNDLE_ENTRY_FOUND_MULTIPLE
#: BUNDLE_BUNDLE_ENTRY_FOUND_MULTIPLE
msgid "Found {0} matches for ''{1}'' in the bundle ({2})"
msgstr "Hittade {0} matchningar för ''{1}'' i bundlen ({2})"

# BUNDLE_BUNDLE_ENTRY_FOUND_MULTIPLE_FRAGMENT
#: BUNDLE_BUNDLE_ENTRY_FOUND_MULTIPLE_FRAGMENT
msgid "Found {0} matches for fragment {2} in resource ''{1}'' in the bundle ({3})"
msgstr "Hittade {0} matchningar för fragment {2} i resursen ''{1}'' i bundlen ({3})"

# BUNDLE_BUNDLE_ENTRY_FULLURL_REQUIRED
#: BUNDLE_BUNDLE_ENTRY_FULLURL_REQUIRED
msgid "Except for transactions and batches, each entry in a Bundle must have a fullUrl which is the identity of the resource in the entry"
msgstr "Förutom för transaktioner och batcher måste varje post i en Bundle ha en fullUrl som är identiteten för resursen i posten"

# BUNDLE_BUNDLE_ENTRY_MULTIPLE_PROFILES_MULTIPLE_MATCHES
#: BUNDLE_BUNDLE_ENTRY_MULTIPLE_PROFILES_MULTIPLE_MATCHES
msgid "The {1} resource matched more than one of the allowed profiles ({3})"
msgstr "Resursen {1} matchade fler än en av de tillåtna profilerna ({3})"

# BUNDLE_BUNDLE_ENTRY_MULTIPLE_PROFILES_NO_MATCH
#: BUNDLE_BUNDLE_ENTRY_MULTIPLE_PROFILES_NO_MATCH
msgid "The {1} resource did not match any of the allowed profiles (Type {2}: {3})"
msgstr "Resursen {1} matchade inte någon av de tillåtna profilerna (typ {2}: {3})"

# BUNDLE_BUNDLE_ENTRY_MULTIPLE_PROFILES_NO_MATCH_REASON
#: BUNDLE_BUNDLE_ENTRY_MULTIPLE_PROFILES_NO_MATCH_REASON
msgid "The {1} resource did not match the profile {2} because: {3}"
msgstr "Resursen {1} matchade inte profilen {2} eftersom: {3}"

# BUNDLE_BUNDLE_ENTRY_NOTFOUND_APPARENT
#: BUNDLE_BUNDLE_ENTRY_NOTFOUND_APPARENT
msgid "Can''t find ''{1}'' in the bundle ({2}). Note that there is a resource in the bundle with the same type and id, but it does not match because of the fullUrl based rules around matching relative references (must be ''{3}'', but found ''{4}'')"
msgid_plural "Can''t find ''{1}'' in the bundle ({2}). Note that there are {0} resources in the bundle with the same type and id, but they do not match because of the fullUrl based rules around matching relative references (must be ''{3}'', but found these: {4})"
msgstr[0] "Kan inte hitta ''{1}'' i bundlen ({2}). Observera att det finns en resurs i bundlen med samma typ och id, men den matchar inte på grund av fullUrl-baserade regler kring matchning av relativa referenser (måste vara ''{3}'', men hittade ''{4}'')"
msgstr[1] "Kan inte hitta ''{1}'' i bundlen ({2}). Observera att det finns {0} resurser i bundlen med samma typ och id, men de matchar inte på grund av fullUrl-baserade regler kring matchning av relativa referenser (måste vara ''{3}'', men hittade dessa: {4})"

# BUNDLE_BUNDLE_ENTRY_NOTFOUND_CANNOT
#: BUNDLE_BUNDLE_ENTRY_NOTFOUND_CANNOT
msgid "Can''t find ''{1}'' in the bundle ({2}). Note that there is a resource in the bundle with the same type and id, but it does not match because of the fullUrl based rules around matching relative references. Found ''{3}'', but it doesn''t match because of the source fullUrl ''{4}''"
msgid_plural "Can''t find ''{1}'' in the bundle ({2}). Note that there are {0} resources in the bundle with the same type and id, but they do not match because of the fullUrl based rules around matching relative references. Found ''{3}'', but none of them match because of the source fullUrl ''{4}''"
msgstr[0] "Kan inte hitta ''{1}'' i bundlen ({2}). Observera att det finns en resurs i bundlen med samma typ och id, men den matchar inte på grund av fullUrl-baserade regler kring matchning av relativa referenser. Hittade ''{3}'', men den matchar inte på grund av käll-fullUrl ''{4}''"
msgstr[1] "Kan inte hitta ''{1}'' i bundlen ({2}). Observera att det finns {0} resurser i bundlen med samma typ och id, men de matchar inte på grund av fullUrl-baserade regler kring matchning av relativa referenser. Hittade ''{3}'', men ingen av dem matchar på grund av käll-fullUrl ''{4}''"

# BUNDLE_BUNDLE_ENTRY_NOTFOUND_FRAGMENT
#: BUNDLE_BUNDLE_ENTRY_NOTFOUND_FRAGMENT
msgctxt "BUNDLE_BUNDLE_ENTRY_NOTFOUND_FRAGMENT"
msgid "Can''t find ''{0}'' in the bundle ({1})"
msgstr "Kan inte hitta ''{0}'' i bundlen ({1})"

# BUNDLE_BUNDLE_ENTRY_REVERSE_MSG
#: BUNDLE_BUNDLE_ENTRY_REVERSE_MSG
msgid "Entry {0} isn''t reachable by traversing forwards from the MessageHeader. Check that this is meant to be included (needed to process the message)"
msgstr "Post {0} kan inte nås genom framåttraversering från MessageHeader. Kontrollera att detta är avsett att inkluderas (behövs för att bearbeta meddelandet)"

# BUNDLE_BUNDLE_ENTRY_REVERSE_R4
#: BUNDLE_BUNDLE_ENTRY_REVERSE_R4
msgid "Entry {0} isn''t reachable by traversing forwards from the Composition. Only Provenance is approved to be used this way (R4 section 3.3.1)"
msgstr "Post {0} kan inte nås genom framåttraversering från Composition. Endast Provenance är godkänd att användas på detta sätt (R4 avsnitt 3.3.1)"

# BUNDLE_BUNDLE_ENTRY_REVERSE_R5
#: BUNDLE_BUNDLE_ENTRY_REVERSE_R5
msgid "Entry {0} isn''t reachable by traversing forwards from the Composition. Check whether this should be linked directly from the composition if it''s a source of narrative content"
msgstr "Post {0} kan inte nås genom framåttraversering från Composition. Kontrollera om denna bör länkas direkt från compositionen om den är en källa till berättande innehåll"

# BUNDLE_BUNDLE_POSSIBLE_MATCH_NO_FU
#: BUNDLE_BUNDLE_POSSIBLE_MATCH_NO_FU
msgid "Entry {0} matches the reference {1} by type and id but it does not match the full target URL {2} by Bundle resolution rules"
msgstr "Post {0} matchar referensen {1} via typ och id men matchar inte den fullständiga mål-URL:en {2} enligt Bundle-upplösningsregler"

# BUNDLE_BUNDLE_POSSIBLE_MATCH_WRONG_FU
#: BUNDLE_BUNDLE_POSSIBLE_MATCH_WRONG_FU
msgid "Entry {0} matches the reference {1} by type and id but its fullUrl {2} does not match the full target URL {3} by Bundle resolution rules"
msgstr "Post {0} matchar referensen {1} via typ och id men dess fullUrl {2} matchar inte den fullständiga mål-URL:en {3} enligt Bundle-upplösningsregler"

# BUNDLE_ENTRY_URL_ABSOLUTE
#: BUNDLE_ENTRY_URL_ABSOLUTE
msgid "The fullUrl must be an absolute URL (not ''{0}'')"
msgstr "fullUrl måste vara en absolut URL (inte ''{0}'')"

# BUNDLE_ENTRY_URL_MATCHES_NO_ID
#: BUNDLE_ENTRY_URL_MATCHES_NO_ID
msgid "The fullUrl ''{0}'' looks like a RESTful server URL, but the resource has no id"
msgstr "fullUrl ''{0}'' ser ut som en RESTful server-URL, men resursen har inget id"

# BUNDLE_ENTRY_URL_MATCHES_TYPE_ID
#: BUNDLE_ENTRY_URL_MATCHES_TYPE_ID
msgid "The fullUrl ''{0}'' looks like a RESTful server URL, so it must end with the correct type and id (/{1}/{2})"
msgstr "fullUrl ''{0}'' ser ut som en RESTful server-URL, så den måste avslutas med rätt typ och id (/{1}/{2})"

# BUNDLE_LINK_SEARCH_NO_DUPLICATES
#: BUNDLE_LINK_SEARCH_NO_DUPLICATES
msgid "The link relationship type ''{0}'' can only occur once"
msgstr "Länkrelationstypen ''{0}'' kan endast förekomma en gång"

# BUNDLE_LINK_SEARCH_PROHIBITED
#: BUNDLE_LINK_SEARCH_PROHIBITED
msgid "The link relationship type ''{0}'' used in search sets is prohibited in this context"
msgstr "Länkrelationstypen ''{0}'' som används i söksätt är förbjuden i denna kontext"

# BUNDLE_LINK_STYELSHEET_EXTERNAL
#: BUNDLE_LINK_STYELSHEET_EXTERNAL
msgid "External Stylesheets other than https://hl7.org/fhir/fhir.css SHOULD not be used"
msgstr "Externa stilmallar utöver https://hl7.org/fhir/fhir.css BÖR inte användas"

# BUNDLE_LINK_STYELSHEET_INSECURE
#: BUNDLE_LINK_STYELSHEET_INSECURE
msgid "The stylesheet reference is not secure"
msgstr "Stilmallsreferensen är inte säker"

# BUNDLE_LINK_STYELSHEET_LINKABLE
#: BUNDLE_LINK_STYELSHEET_LINKABLE
msgid "The stylesheet reference is not a resolvable link"
msgstr "Stilmallsreferensen är inte en lösbar länk"

# BUNDLE_LINK_STYELSHEET_NOT_FOUND
#: BUNDLE_LINK_STYELSHEET_NOT_FOUND
msgid "The stylesheet reference could not be resolved in this bundle"
msgstr "Stilmallsreferensen kunde inte lösas i denna bundle"

# BUNDLE_LINK_UNKNOWN
#: BUNDLE_LINK_UNKNOWN
msgid "The link relationship type ''{0}'' is unknown and not allowed in this context"
msgstr "Länkrelationstypen ''{0}'' är okänd och inte tillåten i denna kontext"

# BUNDLE_POSSSIBLE_MATCHES
#: BUNDLE_POSSSIBLE_MATCHES
msgid "The bundle contains no match for {1} by the rules of Bundle reference resolution, but it has multiple resources that match {0} by resource type and id"
msgstr "Bundlen innehåller ingen matchning för {1} enligt reglerna för Bundle-referensupplösning, men den har flera resurser som matchar {0} via resurstyp och id"

# BUNDLE_RULE_INVALID_INDEX
#: BUNDLE_RULE_INVALID_INDEX
msgid "Bundle Rules index is invalid ({0})"
msgstr "Bundle-regelindex är ogiltigt ({0})"

# BUNDLE_RULE_NONE
#: BUNDLE_RULE_NONE
msgid "No Rule"
msgstr "Ingen regel"

# BUNDLE_RULE_PROFILE_UNKNOWN
#: BUNDLE_RULE_PROFILE_UNKNOWN
msgid "Bundle Rules profile {1} is unknown for {0}"
msgstr "Bundle-regelprofilen {1} är okänd för {0}"

# BUNDLE_RULE_UNKNOWN
#: BUNDLE_RULE_UNKNOWN
msgid "Bundle Rule refers to invalid resource {0}"
msgstr "Bundle-regel refererar till ogiltig resurs {0}"

# BUNDLE_SEARCH_ENTRY_NO_RESOURCE
#: BUNDLE_SEARCH_ENTRY_NO_RESOURCE
msgid "SearchSet Bundle Entries must have resources"
msgstr "Poster i SearchSet-bundle måste ha resurser"

# BUNDLE_SEARCH_ENTRY_NO_RESOURCE_ID
#: BUNDLE_SEARCH_ENTRY_NO_RESOURCE_ID
msgid "Search results must have ids"
msgstr "Sökresultat måste ha id:n"

# BUNDLE_SEARCH_ENTRY_TYPE_NOT_SURE
#: BUNDLE_SEARCH_ENTRY_TYPE_NOT_SURE
msgid "Unable to determine if this resource is a valid resource type for this search"
msgstr "Kan inte avgöra om denna resurs är en giltig resurstyp för denna sökning"

# BUNDLE_SEARCH_ENTRY_WRONG_RESOURCE_TYPE_MODE
#: BUNDLE_SEARCH_ENTRY_WRONG_RESOURCE_TYPE_MODE
msgid "This is not a matching resource type for the specified search ({0} expecting {1})"
msgstr "Detta är inte en matchande resurstyp för den angivna sökningen ({0} förväntar {1})"

# BUNDLE_SEARCH_ENTRY_WRONG_RESOURCE_TYPE_NO_MODE
#: BUNDLE_SEARCH_ENTRY_WRONG_RESOURCE_TYPE_NO_MODE
msgid "This is not a matching resource type for the specified search (is a search mode needed?) ({0} expecting {1})"
msgstr "Detta är inte en matchande resurstyp för den angivna sökningen (behövs ett sökläge?) ({0} förväntar {1})"

# BUNDLE_SEARCH_ENTRY_WRONG_RESOURCE_TYPE_OUTCOME
#: BUNDLE_SEARCH_ENTRY_WRONG_RESOURCE_TYPE_OUTCOME
msgid "This is not an OperationOutcome ({0})"
msgstr "Detta är inte en OperationOutcome ({0})"

# BUNDLE_SEARCH_NOSELF
#: BUNDLE_SEARCH_NOSELF
msgid "SearchSet Bundles should have a self link that specifies what the search was"
msgstr "SearchSet-bundles bör ha en self-länk som anger vad sökningen var"

# BUNDLE_SEARCH_NO_MODE
#: BUNDLE_SEARCH_NO_MODE
msgid "SearchSet bundles should have search modes on the entries"
msgstr "SearchSet-bundles bör ha sökägen på posterna"

# BUNDLE_SEARCH_SELF_NOT_UNDERSTOOD
#: BUNDLE_SEARCH_SELF_NOT_UNDERSTOOD
msgid "No types could be determined from the search string, so the types can''t be checked"
msgstr "Inga typer kunde bestämmas från söksträngen, så typerna kan inte kontrolleras"

# BUNDLE_SIGNATURE_CANON_DIFF
#: BUNDLE_SIGNATURE_CANON_DIFF
msgid "The canonicalization in the digital signature is {0} which doesn't match the value {1} found in the targetFormat"
msgstr "Kanoniseringen i den digitala signaturen är {0} vilket inte matchar värdet {1} som hittas i targetFormat"

# BUNDLE_SIGNATURE_CANON_ERROR
#: BUNDLE_SIGNATURE_CANON_ERROR
msgid "Error parsing the targetFormat ''{0}'': {1}"
msgstr "Fel vid analys av targetFormat ''{0}'': {1}"

# BUNDLE_SIGNATURE_CERT_DETAILS
#: BUNDLE_SIGNATURE_CERT_DETAILS
msgid "Signing Certificate Details: Subject=''{0}'', Issuer=''{1}'', Serial=''{2}''"
msgstr "Signeringscertifikatdetaljer: Subject=''{0}'', Issuer=''{1}'', Serial=''{2}''"

# BUNDLE_SIGNATURE_CERT_SOURCE
#: BUNDLE_SIGNATURE_CERT_SOURCE
msgid "Signing Certificate Source: {0}"
msgstr "Signeringscertifikatkälla: {0}"

# BUNDLE_SIGNATURE_CHECKED_DATA_B64
#: BUNDLE_SIGNATURE_CHECKED_DATA_B64
msgid "The signature data is not valid base64 content, but it looks like native application/jose, so it will be checked anyway"
msgstr "Signaturdata är inte giltigt base64-innehåll, men det ser ut som inbyggt application/jose, så det kommer att kontrolleras ändå"

# BUNDLE_SIGNATURE_DIGSIG_INVALID
#: BUNDLE_SIGNATURE_DIGSIG_INVALID
msgid "The digital signature is invalid XML: {0}"
msgstr "Den digitala signaturen är ogiltig XML: {0}"

# BUNDLE_SIGNATURE_DIGSIG_NO_CERT
#: BUNDLE_SIGNATURE_DIGSIG_NO_CERT
msgid "Didn''t find a provided X509 certificate in the digital signature, so can''t verify the signature"
msgstr "Hittade inget tillhandahållet X509-certifikat i den digitala signaturen, så signaturen kan inte verifieras"

# BUNDLE_SIGNATURE_DIGSIG_NO_REFERENCES
#: BUNDLE_SIGNATURE_DIGSIG_NO_REFERENCES
msgid "No references found in the digital signature SignedInfo"
msgstr "Inga referenser hittades i den digitala signaturens SignedInfo"

# BUNDLE_SIGNATURE_DIGSIG_NO_SIG_TIME
#: BUNDLE_SIGNATURE_DIGSIG_NO_SIG_TIME
msgid "No SigningTime element found in the digital signature"
msgstr "Inget SigningTime-element hittades i den digitala signaturen"

# BUNDLE_SIGNATURE_DIGSIG_NO_SV
#: BUNDLE_SIGNATURE_DIGSIG_NO_SV
msgid "Didn''t find a provided signedValue in the digital signature, so can''t verify the signature"
msgstr "Hittade inget tillhandahållet signedValue i den digitala signaturen, så signaturen kan inte verifieras"

# BUNDLE_SIGNATURE_DIGSIG_REFERENCES_TOO_MANY
#: BUNDLE_SIGNATURE_DIGSIG_REFERENCES_TOO_MANY
msgid "Too many references found in the digital signature SignedInfo - not understood"
msgstr "För många referenser hittades i den digitala signaturens SignedInfo - inte förstådda"

# BUNDLE_SIGNATURE_DIGSIG_REFERENCE_NOT_UNDERSTOOD
#: BUNDLE_SIGNATURE_DIGSIG_REFERENCE_NOT_UNDERSTOOD
msgid "The reference in the SignedInfo in the digital signature is ''{0}'' which is not understood (or correct?)"
msgstr "Referensen i SignedInfo i den digitala signaturen är ''{0}'' vilken inte förstås (eller är korrekt?)"

# BUNDLE_SIGNATURE_DIGSIG_REFERENCE_TYPE_NOT_UNDERSTOOD
#: BUNDLE_SIGNATURE_DIGSIG_REFERENCE_TYPE_NOT_UNDERSTOOD
msgid "The second reference in the SignedInfo in the digital signature has type ''{0}'' which is not understood (or correct?)"
msgstr "Den andra referensen i SignedInfo i den digitala signaturen har typen ''{0}'' vilken inte förstås (eller är korrekt?)"

# BUNDLE_SIGNATURE_DIGSIG_SIGNED_INVALID
#: BUNDLE_SIGNATURE_DIGSIG_SIGNED_INVALID
msgid "The digital signature is not valid XML: {0}"
msgstr "Den digitala signaturen är inte giltig XML: {0}"

# BUNDLE_SIGNATURE_DIGSIG_SIGNED_INVALID_XML
#: BUNDLE_SIGNATURE_DIGSIG_SIGNED_INVALID_XML
msgid "The signed bytes provided could not be read - invalid XML Structure ({0})"
msgstr "De tillhandahållna signerade byten kunde inte läsas - ogiltig XML-struktur ({0})"

# BUNDLE_SIGNATURE_DIGSIG_SIGNED_MISMATCH
#: BUNDLE_SIGNATURE_DIGSIG_SIGNED_MISMATCH
msgctxt "BUNDLE_SIGNATURE_DIGSIG_SIGNED_MISMATCH"
msgid "The signature cannot be valid because the content to sign ({0} bytes} is not the same as the signed content ({1} bytes)"
msgstr "Signaturen kan inte vara giltig eftersom innehållet att signera ({0} byte} inte är detsamma som det signerade innehållet ({1} byte)"

# BUNDLE_SIGNATURE_DIGSIG_SIGNED_SAME
#: BUNDLE_SIGNATURE_DIGSIG_SIGNED_SAME
msgid "The signed bytes are identical, so the signature failure is not because the content changed. Check Canonicalization carefully (including whitespace)"
msgstr "De signerade byten är identiska, så signaturfelet beror inte på att innehållet ändrats. Kontrollera kanoniseringen noggrant (inklusive blanksteg)"

# BUNDLE_SIGNATURE_DIGSIG_SIGNED_XML_MATCHES
#: BUNDLE_SIGNATURE_DIGSIG_SIGNED_XML_MATCHES
msgid "The actual XML structures of payload and canonicalized form do match, so the issue is in the canonicalization"
msgstr "De faktiska XML-strukturerna för payload och kanoniserad form matchar, så problemet finns i kanoniseringen"

# BUNDLE_SIGNATURE_DIGSIG_SIGNED_XML_NO_MATCH
#: BUNDLE_SIGNATURE_DIGSIG_SIGNED_XML_NO_MATCH
msgid "The actual XML structures of payload and canonicalized form do not match: {0}"
msgstr "De faktiska XML-strukturerna för payload och kanoniserad form matchar inte: {0}"

# BUNDLE_SIGNATURE_DIGSIG_SIG_ERROR
#: BUNDLE_SIGNATURE_DIGSIG_SIG_ERROR
msgid "Error verifying the signature: {0}"
msgstr "Fel vid verifiering av signaturen: {0}"

# BUNDLE_SIGNATURE_DIGSIG_WHEN_MISMATCH
#: BUNDLE_SIGNATURE_DIGSIG_WHEN_MISMATCH
msgid "The time in the digital signature {0} is not the same as the stated time {1}"
msgstr "Tiden i den digitala signaturen {0} är inte densamma som den angivna tiden {1}"

# BUNDLE_SIGNATURE_DIGSIG_X509_ERROR
#: BUNDLE_SIGNATURE_DIGSIG_X509_ERROR
msgctxt "BUNDLE_SIGNATURE_DIGSIG_X509_ERROR"
msgid "Unable to parse X509 Certificate: {0}"
msgstr "Kan inte tolka X509-certifikat: {0}"

# BUNDLE_SIGNATURE_HEADER_CERT_NOT_FOUND
#: BUNDLE_SIGNATURE_HEADER_CERT_NOT_FOUND
msgid "Didn''t find a matching certificate for the ''kid'' {0} in the header, so can''t verify the signature"
msgstr "Hittade inget matchande certifikat för ''kid'' {0} i headern, så signaturen kan inte verifieras"

# BUNDLE_SIGNATURE_HEADER_CERT_NOT_FOUND_ERROR
#: BUNDLE_SIGNATURE_HEADER_CERT_NOT_FOUND_ERROR
msgid "Error scanning for certificate to match kid {0}: {1}"
msgstr "Fel vid sökning efter certifikat som matchar kid {0}: {1}"

# BUNDLE_SIGNATURE_HEADER_NO_KID_OR_CERT
#: BUNDLE_SIGNATURE_HEADER_NO_KID_OR_CERT
msgid "Didn''t find a provided certificate or a ''kid'' in the header, so can''t verify the signature"
msgstr "Hittade inget tillhandahållet certifikat eller ''kid'' i headern, så signaturen kan inte verifieras"

# BUNDLE_SIGNATURE_HEADER_NO_SIG_TIME
#: BUNDLE_SIGNATURE_HEADER_NO_SIG_TIME
